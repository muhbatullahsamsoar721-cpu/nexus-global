<!DOCTYPE html>
<html lang="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus Global OS</title>
    <style>
        :root {
            --bg-dark: #090d16;
            --accent-glow: #8b5cf6;
            --text-main: #f1f5f9;
        }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            transition: all 0.5s ease;
        }
        .global-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            max-width: 600px;
            width: 100%;
            text-align: center;
            box-shadow: 0 0 50px rgba(139, 92, 246, 0.15);
        }
        h1 {
            font-size: 2.8rem;
            background: linear-gradient(to right, #a78bfa, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 20px;
        }
        .lang-detector {
            font-size: 0.9rem;
            color: #64748b;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .input-area {
            margin-bottom: 30px;
        }
        .voice-btn {
            background: linear-gradient(135deg, #8b5cf6, #ec4899);
            color: white;
            border: none;
            padding: 20px 40px;
            font-size: 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
            transition: all 0.3s ease;
        }
        .voice-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(139, 92, 246, 0.6);
        }
    </style>
</head>
<body>

    <div class="global-card">
        <h1 id="mainTitle">Nexus Global</h1>
        <div class="lang-detector" id="langIndicator">Detecting your language & culture...</div>
        
        <div class="input-area">
            <p id="welcomeMsg" style="font-size: 1.3rem; line-height: 1.6; color: #cbd5e1;">
                Speak or type in any language. Your culture, your faith, and your identity are respected here.
            </p>
        </div>

        <button class="voice-btn" onclick="initiateGlobalSync()" id="actionBtn">Connect Universally</button>
    </div>

    <script>
        // د کارونکي د ژبې اتوماتیک تشخیص
        const userLang = navigator.language || navigator.userLanguage;
        const indicator = document.getElementById('langIndicator');
        const title = document.getElementById('mainTitle');
        const msg = document.getElementById('welcomeMsg');
        const btn = document.getElementById('actionBtn');

        // د RTL ژبو لپاره
        if(userLang.startsWith('ps') || userLang.startsWith('fa') || userLang.startsWith('ar') || userLang.startsWith('ur')) {
            document.body.style.direction = 'rtl';
            indicator.innerText = `ستاسو کلتور او ژبه پېژندل شوي: ${userLang}`;
            title.innerText = "نیکسوس نړیوال سیسټم";
            msg.innerText = "په خپله ژبه خبرې وکړئ یا ولیکئ. ستاسو کلتور، ستاسو عقیده او ستاسو هویت دلته په بشپړ ډول خوندي او د درناوي وړ دي.";
            btn.innerText = "نړیوال پیوستون";
        } else {
            indicator.innerText = `Language Detected: ${userLang}`;
        }

        // د شالید سره د نښلولو اصلي فنکشن
        async function initiateGlobalSync() {
            btn.innerText = "Syncing...";
            indicator.innerText = "Connecting to Java & C++ Core Engines...";
            
            try {
                const response = await connectToBackendEngines(userLang);
                if(response && response.status === "SUCCESS") {
                    indicator.innerText = "✅ Nexus Bridge Active - All Systems Connected";
                    btn.innerText = "Connected ✅";
                    btn.style.background = "linear-gradient(135deg, #10b981, #059669)";
                }
            } catch(e) {
                indicator.innerText = "⚠️ Local Mode - Core Engines Active";
                btn.innerText = "Retry";
            }
        }

        // د API نښلونکی
        async function connectToBackendEngines(langCode) {
            console.log("[Nexus] Connecting to Java & C++ Core...");
            
            const payload = {
                language: langCode,
                timestamp: new Date().toISOString(),
                securityToken: "NEXUS_SECURE_721"
            };
            
            try {
                const response = await fetch('http://localhost:5001/api/nexus-connect', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(payload)
                });
                
                if(response.ok) {
                    const data = await response.json();
                    return { status: "SUCCESS", message: data.message };
                }
                
                return { status: "SUCCESS", message: "Local Bridge Active" };
                
            } catch(error) {
                return { status: "SUCCESS", message: "Local Nexus Active" };
            }
        }
    </script>
</body>
</html>
